# Ignore all local caches, logs, and installation binaries
tmp/
antigravity-backup/
antigravity-browser-profile/
antigravity-cli/
antigravity-ide/
antigravity/
config/
history/
projects.json

# Ignore sensitive credentials
google_accounts.json
oauth_creds.json

# Ignore local secrets and private keys
.env
.env.*
*.pem
*.key
*.p12
*.pkcs12
*.json.key
secrets/

# Ignore Python compilation artifacts and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/

# Ignore autogenerated skill references
skills/*/references/
