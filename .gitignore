# Ignore all local caches, logs, and installation binaries
tmp/
antigravity-backup/
antigravity-browser-profile/
antigravity-cli/bin/
antigravity-cli/builtin/
antigravity-cli/cache/
antigravity-cli/crashes/
antigravity-cli/implicit/
antigravity-cli/knowledge/
antigravity-cli/log/
antigravity-cli/updater/
antigravity-cli/brain/
antigravity-cli/conversations/
antigravity-ide/
antigravity/
config/
history/

# Ignore logs and state database files
*.log
antigravity-cli/cli.log
antigravity-cli/conversation_summaries.db
antigravity-cli/history.jsonl
antigravity-cli/last_check.timestamp
antigravity-cli/jetski_state.pbtxt

# Ignore machine-specific configuration and IDs
antigravity-cli/settings.json
antigravity-cli/installation_id
projects.json

# Ignore sensitive credentials
google_accounts.json
oauth_creds.json

# Ignore local secrets and private keys
.env
.env.*
*.pem
*.key
*.p12
*.pkcs12
*.json.key
secrets/

# Ignore Python compilation artifacts and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
